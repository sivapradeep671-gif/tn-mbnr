# ==============================================================
# TN-MBNR TrustReg Platform - Environment Configuration Blueprint
# ==============================================================
# INSTRUCTIONS:
# Copy this file to '.env' for local development.
# For production (Render), paste these keys into the Environment section.
# ==============================================================

# 1. Database Configuration
# If MONGODB_URI is left blank, the system automatically and safely 
# falls back to the local SQLite Registry (tn_mbnr.db).
MONGODB_URI="mongodb+srv://<username>:<password>@cluster.mongodb.net/tn_mbnr"

# 2. AI Security & Fraud Detection
# Required for the AI-powered Inspector Field App to analyze logos and detect counterfeiters.
VITE_GEMINI_API_KEY="your-google-gemini-api-key"

# 3. Notification Nodes (Twilio SMS)
# Used for sending real-time alerts to businesses regarding their Verification status.
# If left blank, SMS dispatch defaults to [MOCK MODE] in the console.
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# 4. Email Notification Node (SendGrid)
# If left blank, Email dispatch defaults to [MOCK MODE].
SENDGRID_API_KEY="your-sendgrid-api-key"
SENDGRID_FROM_EMAIL="alerts@tn-mbnr.gov.in"

# 5. Cryptography Keys (Optional)
# These are handled securely by default, but can be explicitly overridden.
# QR_SECRET_KEY="MBNR_SECURE_TOKEN_2026_GRID"
